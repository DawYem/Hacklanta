# Copy this file to `.env` in the project root and fill in values.

# Quest API (optional). Empty in dev — Vite proxies /api → http://localhost:5050
VITE_API_BASE_URL=

# Google Maps browser key — paste key after = (no spaces). Restart Vite after changes.
VITE_MAPS_PLATFORM_API_KEY=

# Optional server-only key (not bundled in the client)
MAPS_PLATFORM_API_KEY=

# Optional: OpenWeather — live weather on quest screen (server calls OpenWeather API)
OPENWEATHER_API_KEY=
