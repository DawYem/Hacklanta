# Copy this file to `.env` in the project root and fill in values.

# Quest API — leave empty in local dev (Vite proxies /api → localhost:5050).
# Production (e.g. Vercel): set to Railway HTTPS origin only, no trailing slash:
# VITE_API_BASE_URL=https://your-service.up.railway.app
VITE_API_BASE_URL=

# Google Maps browser key — paste key after = (no spaces). Restart Vite after changes.
VITE_MAPS_PLATFORM_API_KEY=

# Optional server-only key (not bundled in the client)
MAPS_PLATFORM_API_KEY=

# Optional: OpenWeather — live weather on quest screen (server calls OpenWeather API)
OPENWEATHER_API_KEY=

# Optional: Gemini — AI-generated quest text (get an API key from Google AI Studio, NOT an OAuth "Client ID")
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override if the default is unavailable in your project
# GEMINI_MODEL=gemini-1.5-flash
